进入 backend 目录后执行：

cd d:\mathnode_backend
pip install -r requirements.txt
$env:APP_ENV="dev"
$env:LOG_ENABLED="true"
$env:LOG_FORMAT="detailed"
$env:LOG_LEVEL="INFO"
$env:APP_LOG_LEVEL="DEBUG"
$env:THIRD_PARTY_LOG_LEVEL="WARNING"
$env:UVICORN_LOG_LEVEL="INFO"
$env:UVICORN_ACCESS_LOG="false"
$env:REQUEST_LOG_ENABLED="true"
$env:REQUEST_LOG_LEVEL="INFO"
$env:HTTP_CLIENT_DEBUG="false"
$env:CONTENT_BACKEND="memory"
$env:INDEX_BACKEND="memory"
$env:BIZ_BACKEND="sqlite"
$env:CONTENT_JSON_PATH="app/data/canonical_content_v2.json"
$env:ENABLE_DEBUG_ENDPOINTS="true"
$env:WECHAT_MINIAPP_APPID="你的微信appid"
$env:WECHAT_MINIAPP_SECRET="你的微信secret"
$env:JWT_SECRET="请替换为高强度随机密钥"
$env:JWT_EXPIRE_SECONDS="86400"
uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 --log-level debug --access-log
启动后打开：

http://127.0.0.1:8000/docs


应用构建自检
命令：python -c "from app.main import create_app; app=create_app(); print(app.title, app.version)"
输出：Math Search API 0.1.0


systemd Environment 示例（生产建议）：
Environment=PYTHONUNBUFFERED=1
Environment=APP_ENV=prod
Environment=LOG_ENABLED=true
Environment=LOG_FORMAT=standard
Environment=LOG_LEVEL=INFO
Environment=APP_LOG_LEVEL=INFO
Environment=THIRD_PARTY_LOG_LEVEL=WARNING
Environment=UVICORN_LOG_LEVEL=INFO
Environment=UVICORN_ACCESS_LOG=false
Environment=REQUEST_LOG_ENABLED=true
Environment=REQUEST_LOG_LEVEL=INFO
Environment=HTTP_CLIENT_DEBUG=false
Environment=BOOTSTRAP_LOG_VERBOSE=false
